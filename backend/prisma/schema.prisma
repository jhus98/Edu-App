generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

enum Category {
  HISTORY
  SCIENCE
  SPACE
  NATURE
  GEOGRAPHY
  PHILOSOPHY
  TECHNOLOGY
  ART
}

enum CardStatus {
  PENDING_AUTO
  PENDING_HUMAN
  APPROVED
  REJECTED
  FLAGGED
}

enum VerificationCheckType {
  SOURCE_CHECK
  AI_FACTCHECK
  CLAIM_CROSSREF
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

model User {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  streakCount  Int      @default(0)
  lastActiveAt DateTime @default(now())
  preferences  Json     @default("{\"categories\": [], \"notificationsEnabled\": true}")
  pushToken    String?

  interactions UserCardInteraction[]
  flags        Flag[]
  approvedCards Card[]               @relation("ApprovedBy")

  @@map("users")
}

model Card {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title              String
  body               String
  sourceTitle        String
  sourceUrl          String
  category           Category
  status             CardStatus @default(PENDING_AUTO)
  confidenceScore    Int        @default(0)
  version            Int        @default(1)
  createdAt          DateTime   @default(now())
  approvedAt         DateTime?
  approvedById       String?    @db.Uuid
  generationMetadata Json       @default("{}")
  embedding          Unsupported("vector(1536)")?

  approvedBy    User?               @relation("ApprovedBy", fields: [approvedById], references: [id])
  versions      CardVersion[]
  interactions  UserCardInteraction[]
  flags         Flag[]
  verifications VerificationLog[]

  @@map("cards")
}

model CardVersion {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cardId      String   @db.Uuid
  version     Int
  title       String
  body        String
  sourceTitle String
  sourceUrl   String
  reason      String
  createdAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_versions")
}

model UserCardInteraction {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String   @db.Uuid
  cardId     String   @db.Uuid
  liked      Boolean  @default(false)
  saved      Boolean  @default(false)
  flagged    Boolean  @default(false)
  flagReason String?
  seenAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("user_card_interactions")
}

model Flag {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cardId    String   @db.Uuid
  userId    String   @db.Uuid
  reason    String
  createdAt DateTime @default(now())
  resolved  Boolean  @default(false)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flags")
}

model VerificationLog {
  id        String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cardId    String                @db.Uuid
  checkType VerificationCheckType
  passed    Boolean
  details   Json
  createdAt DateTime              @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("verification_logs")
}
